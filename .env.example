# PostgreSQL connection string used by the Appels d'offres repository,
# processing jobs, documents, and audit logs. Required.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Canonical n8n launch webhook called by POST /api/appels-offres/[code]/analyse
# and the compatibility route POST /api/generate. Required.
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/launch

# Bearer token the platform sends when launching a canonical analysis request
# to n8n. Must match the token the n8n workflow validates on launch. Required.
N8N_WEBHOOK_TOKEN=replace-with-launch-token

# Bearer token n8n must send back on the canonical callback
# (POST /api/fiche/callbacks/n8n). Required.
PLATFORM_CALLBACK_TOKEN=replace-with-callback-bearer-token

# Shared HMAC secret used to compute/verify X-Callback-Signature on the
# canonical n8n callback route. Required.
N8N_CALLBACK_SECRET=replace-with-hmac-secret

# Public base URL the platform uses to build the canonical callback URL
# shared with n8n (<base>/api/fiche/callbacks/n8n). Required.
PLATFORM_PUBLIC_BASE_URL=https://platform.example.com

# Contract version enforced on both launch and callback exchanges. Optional,
# defaults to 1.0.
N8N_CONTRACT_VERSION=1.0

# Max wait (ms) for the immediate 202 Accepted response from n8n. Optional,
# defaults to 10000.
N8N_LAUNCH_TIMEOUT_MS=10000

# Max accepted CDC PDF size in bytes. Optional, defaults to 52428800 (50 MB).
MAX_CDC_UPLOAD_BYTES=52428800

# Legacy compatibility route only (POST /api/fiche/[code]/complete). No longer
# part of the canonical contract - the active n8n workflow calls the canonical
# callback route above instead. Keep only if something still posts to the old
# route; otherwise safe to leave unset.
N8N_COMPLETE_SECRET=replace-with-legacy-complete-secret

# NOT read by this Next.js app. This is the n8n RUNTIME's own environment
# variable (used by the Gemini HTTP request node inside the workflow - see
# scripts/n8n-tests/start_n8n_canonical_test.cmd). Documented here only so
# the full set of variables both sides need is in one place.
GEMINI_API_KEY=replace-with-gemini-api-key
